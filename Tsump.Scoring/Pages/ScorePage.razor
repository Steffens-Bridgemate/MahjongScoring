@page "/score"
@using System.Text.Json
@inject NavigationManager Nav
@inject LanguageService Lang
@inject LocalStorageService Storage
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Tsumo! Scoring</PageTitle>

@if (decodeError)
{
    <div class="alert alert-danger">
        <strong>@Lang.Get("ScoringInvalidLink")</strong>
        <div class="small mt-1">@Lang.Get("ScoringInvalidLinkHint")</div>
    </div>
}
else if (invite == null || tableAssignment == null)
{
    <p>@Lang.Get("Loading")</p>
}
else
{
    @if (!string.IsNullOrEmpty(invite.Title))
    {
        <h5 class="text-muted mb-2">@invite.Title</h5>
    }
    <h1 class="mb-3">@Lang.Get("Table") @invite.TableNumber</h1>

    <ScoreTable @key="clearVersion"
                Table="tableAssignment"
                PlayerNameResolver="ResolveName"
                OnScoresComplete="OnScoresComplete"
                OnScoresCleared="OnScoresCleared"
                DefaultStartingPoints="invite.StartingPoints"
                Uma4Players="uma4"
                Uma3Players="uma3"
                ReadOnlyStart="true" />

    <div class="mt-3 d-flex align-items-center flex-wrap gap-2">
        @if (resultReady)
        {
            <button class="btn btn-success" @onclick="CopyResultLink">
                <i class="bi bi-clipboard me-1"></i>@(copied ? Lang.Get("Copied") : Lang.Get("CopyResultLink"))
            </button>
            <button class="btn btn-outline-success"
                    @onclick="ShowResultQr"
                    title="@Lang.Get("ShowQrCode")"
                    aria-label="@Lang.Get("ShowQrCode")">
                <i class="bi bi-qr-code"></i>
            </button>
            <span class="text-muted small">@Lang.Get("ResultReadyHint")</span>
        }
        else
        {
            <span class="text-muted">@Lang.Get("FillInScoresHint")</span>
        }
    </div>

    <QrCodeModal IsOpen="showResultQr" Url="@resultQrUrl" Title="@resultQrTitle"
                 Subtitle="@Lang.Get("QrCodeResultSubtitle")"
                 Overlay="@Tsump.Scoring.QrCodeRenderer.Overlays.ScoringResult"
                 OnClose="CloseResultQr"
                 OnSave="DownloadResultQr" />
}

@code {
    private ScoringInvite? invite;
    private TableAssignment? tableAssignment;
    private List<int> uma3 = new();
    private List<int> uma4 = new();
    private bool decodeError;
    private bool resultReady;
    private bool copied;
    private int clearVersion;
    private bool showResultQr;
    private string? resultQrUrl;
    private string? resultQrTitle;
    private string StorageKey => invite == null ? "" : $"tsump_scoring_{invite.ContextId}_{invite.TableNumber}";

    protected override void OnInitialized()
    {
        Lang.OnLanguageChanged += StateHasChanged;
        DecodePayloadFromUrl();
    }

    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;

    private void DecodePayloadFromUrl()
    {
        var uri = new Uri(Nav.Uri);
        var fragment = uri.Fragment.TrimStart('#');
        if (string.IsNullOrEmpty(fragment))
        {
            decodeError = true;
            return;
        }

        // Fragment is "p=<payload>" optionally followed by "&l=<lang>" (the organizer's primary
        // language), or — for the oldest links — just "<payload>". Parse the &-separated params.
        var payload = fragment;
        string? langParam = null;
        foreach (var part in fragment.Split('&'))
        {
            var eq = part.IndexOf('=');
            var key = eq >= 0 ? part.Substring(0, eq) : part;
            var value = eq >= 0 ? part.Substring(eq + 1) : "";
            if (key == "p") payload = value;
            else if (key == "l") langParam = value;
        }

        // Display the scoring app in the language the organizer specified.
        if (!string.IsNullOrEmpty(langParam))
            Lang.SetLanguage(langParam);

        invite = ScoringPayloadCodec.DecodeInvite(payload);
        if (invite == null
            || invite.PlayerNames == null
            || invite.PlayerNames.Count < 3 || invite.PlayerNames.Count > 4)
        {
            decodeError = true;
            return;
        }

        // Split Uma into 3/4 buckets based on the table size — the other one stays empty.
        if (invite.PlayerNames.Count == 3)
            uma3 = new List<int>(invite.Uma);
        else
            uma4 = new List<int>(invite.Uma);

        // The wire format doesn't carry PlayerIds — the result rides back by position. We
        // still need Guids internally because ScoreTable wires up edits via PlayerScore.PlayerId.
        // Synthesise one per slot; same order as invite.PlayerNames, never leaves this session.
        tableAssignment = new TableAssignment
        {
            TableNumber = invite.TableNumber,
            PlayerIds = invite.PlayerNames.Select(_ => Guid.NewGuid()).ToList(),
            Score = new TableScore(),
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && invite != null && tableAssignment != null)
        {
            // Initialise first so PlayerScores has the real players + Mr. X entries before
            // we try to restore values onto them. (The previous order was the opposite,
            // restoring onto an empty PlayerScores list and silently dropping the data.)
            ScoreTable.InitializeScores(new() { tableAssignment }, Lang.Get, invite.StartingPoints);

            var saved = await Storage.GetAsync<SavedScore>(StorageKey);
            if (saved != null)
            {
                // Position-based restore — the SavedEntry at index i applies to the i-th
                // non-virtual PlayerScore. (Synthetic PlayerIds are regenerated on every
                // decode, so we can't match by Id anymore — but the order is stable.)
                var realPlayers = tableAssignment.Score!.PlayerScores.Where(p => !p.IsVirtual).ToList();
                for (int i = 0; i < saved.Entries.Count && i < realPlayers.Count; i++)
                {
                    var entry = saved.Entries[i];
                    realPlayers[i].EndPoints = entry.EndPoints;
                    realPlayers[i].Loan = entry.Loan;
                    realPlayers[i].Penalty = entry.Penalty;
                }

                // Re-derive Mr. X (not persisted) and Uma from the restored real-player values.
                ScoreTable.DeriveVirtualEnd(tableAssignment);
                ScoreTable.CalculateUma(tableAssignment, uma3, uma4);

                // If the restored state is already valid, surface the "Copy result link"
                // button without waiting for the user to retype anything.
                if (tableAssignment.Score!.PlayerScores.All(p => p.EndPoints.HasValue)
                    && tableAssignment.Score.PlayerScores.Sum(p => p.Difference) == 0)
                {
                    resultReady = true;
                }
            }

            StateHasChanged();
        }
    }

    private string ResolveName(Guid id)
    {
        if (invite == null || tableAssignment == null) return id.ToString();
        var idx = tableAssignment.PlayerIds.IndexOf(id);
        return idx >= 0 && idx < invite.PlayerNames.Count ? invite.PlayerNames[idx] : id.ToString();
    }

    private async Task OnScoresComplete()
    {
        resultReady = true;
        await PersistInProgress();
    }

    private async Task OnScoresCleared()
    {
        // ScoreTable has already reset the model. We just need to drop the cached progress,
        // hide the "Copy result" button, and force a clean re-render of the inputs.
        resultReady = false;
        copied = false;
        await Storage.RemoveAsync(StorageKey);
        clearVersion++;
        StateHasChanged();
    }

    private async Task PersistInProgress()
    {
        if (invite == null || tableAssignment?.Score == null) return;
        var saved = new SavedScore(tableAssignment.Score.PlayerScores
            .Where(p => !p.IsVirtual)
            .Select(p => new SavedEntry(p.EndPoints, p.Loan, p.Penalty))
            .ToList());
        await Storage.SetAsync(StorageKey, saved);
    }

    private (string url, string title)? BuildResultUrl()
    {
        if (invite == null || tableAssignment?.Score == null) return null;

        // Position-based — each entry [endPoints, loan, penalty]. The organizer pairs by
        // index against the table's known PlayerIds order. See ScoringPayloadCodec.Score*.
        var scores = tableAssignment.Score.PlayerScores
            .Where(p => !p.IsVirtual && p.EndPoints.HasValue)
            .Select(p => new[] { p.EndPoints!.Value, p.Loan, p.Penalty })
            .ToList();

        var result = new ScoringResult(invite.ContextId, invite.TableNumber, scores);
        var encoded = ScoringPayloadCodec.EncodeResult(result);

        // Build the return URL. The organizer's app lives at a different origin than this
        // scoring app, so use the OrganizerUrl carried by the invite. Fall back to this
        // app's own origin only if the invite didn't include one.
        var organizerBase = !string.IsNullOrWhiteSpace(invite.OrganizerUrl)
            ? invite.OrganizerUrl!.TrimEnd('/')
            : Nav.BaseUri.TrimEnd('/');
        var importUrl = $"{organizerBase}/import-score#r={encoded}";
        var label = invite.Title ?? $"Table {invite.TableNumber}";
        return (importUrl, label);
    }

    private void ShowResultQr()
    {
        var built = BuildResultUrl();
        if (built == null) return;
        // Wrap the URL with framing markers FOR THE QR ONLY — the organizer's HID scanner
        // types these out and the import panel detects them as a complete scan. The
        // clipboard message (CopyResultLink) uses the plain URL so WhatsApp's link
        // detection and tap-to-open keep working.
        resultQrUrl = $"{ScoringPayloadCodec.ScanFrameStart}{built.Value.url}{ScoringPayloadCodec.ScanFrameEnd}";
        // Short title for the QR modal — full label/date is in the WhatsApp message.
        resultQrTitle = invite != null
            ? $"{Lang.Get("Hanchan")} {invite.SessionNumber} — {Lang.Get("Table")} {invite.TableNumber}"
            : built.Value.title;
        showResultQr = true;
        StateHasChanged();
        // No auto-copy to clipboard. The user explicitly opts in via the floppy "Save as"
        // button in the modal header — see DownloadResultQr.
    }

    private void CloseResultQr()
    {
        showResultQr = false;
        resultQrUrl = null;
        resultQrTitle = null;
    }

    private async Task DownloadResultQr()
    {
        if (string.IsNullOrEmpty(resultQrUrl)) return;
        var svg = Tsump.Scoring.QrCodeRenderer.ToSvg(resultQrUrl);
        var overlay = Tsump.Scoring.QrCodeRenderer.Overlays.ScoringResult;
        // Build a safe filename from the modal title; fall back to "result" if unset.
        var rawTitle = resultQrTitle ?? "result";
        var safeTitle = string.Concat(rawTitle.Select(c => char.IsLetterOrDigit(c) || c == '-' || c == '_' ? c : '_'));
        var filename = $"{safeTitle}.png";
        await JS.InvokeVoidAsync("downloadQrAsPng", svg, 480, resultQrTitle, overlay.BackgroundColor, "white", filename);
    }

    private async Task CopyResultLink()
    {
        var built = BuildResultUrl();
        if (built == null) return;

        var message = $"✅ {built.Value.title}\n{Lang.Get("ShareResultInstruction")}\n{built.Value.url}";
        await JS.InvokeVoidAsync("copyTextToClipboard", message);
        copied = true;
        StateHasChanged();
        await Task.Delay(2000);
        copied = false;
        StateHasChanged();
    }

    // Local in-progress persistence. PlayerId is no longer stored here — restore is by
    // position (the SavedEntry at index i applies to the i-th non-virtual PlayerScore).
    private record SavedScore(List<SavedEntry> Entries);
    private record SavedEntry(int? EndPoints, int Loan, int Penalty);
}
